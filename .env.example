# ------------------------------------------------------------------
# EmailJS configuration for the contact form (src/utils/email.ts)
# Create a free account at https://www.emailjs.com, then fill these in.
# Never commit your real .env file — only .env.example is tracked.
# ------------------------------------------------------------------

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Optional: if you'd rather send the form to your own backend endpoint
# instead of EmailJS, set this and the contact form will POST to it.
VITE_CONTACT_API_ENDPOINT=

# Canonical site URL, used for SEO metadata, sitemap and structured data.
VITE_SITE_URL=https://your-domain.com
